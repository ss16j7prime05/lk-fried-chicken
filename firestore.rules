rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return isSignedIn() ? userDoc().role : "";
    }

    function myPhone() {
      return isSignedIn() ? userDoc().phone : "";
    }

    // ไม่มีฟิลด์ status เลย = บัญชีเก่าก่อนมีระบบอนุมัติ ถือว่าอนุมัติแล้ว (ไม่ล็อกผู้ใช้เดิม)
    function myStatus() {
      return isSignedIn() ? userDoc().status : null;
    }
    function isApprovedOrLegacy() {
      return myStatus() == null || myStatus() == "approved" || myStatus() == "active";
    }

    // ---------- users ----------
    // ผู้ใช้แก้ไขเอกสารของตัวเองได้ (ยกเว้นฟิลด์ status) / admin อ่าน-แก้ไขได้ทั้งหมด (รวมการอนุมัติ/ปฏิเสธ)
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || role() == "admin");

      // สมัครสมาชิกใหม่: ตั้ง status ได้แค่ "active" (customer) หรือ "pending" (store/rider) เท่านั้น
      // ห้ามสมัครมาแล้วตั้ง status เป็น "approved" เอง
      allow create: if isSignedIn() && request.auth.uid == uid &&
        (request.resource.data.status == "active" || request.resource.data.status == "pending");

      // แก้ไขโปรไฟล์ตัวเองได้ตามปกติ แต่ "ห้ามเปลี่ยน status เอง" (ป้องกันร้าน/ไรเดอร์ตั้ง approved เอง)
      // admin แก้ไขได้ทุกฟิลด์ รวมการอนุมัติ/ปฏิเสธ (เปลี่ยน status)
      allow update: if role() == "admin" ||
        (isSignedIn() && request.auth.uid == uid &&
          request.resource.data.status == resource.data.status);

      allow delete: if role() == "admin";

      // ---------- addresses (สมุดที่อยู่จัดส่งของลูกค้า) ----------
      // เจ้าของอ่าน/เขียน/ลบ ที่อยู่ของตัวเองได้เต็มสิทธิ์ ; admin อ่านได้ (ดูข้อมูลลูกค้า)
      match /addresses/{addressId} {
        allow read: if isSignedIn() && (request.auth.uid == uid || role() == "admin");
        allow write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // ---------- menus / options ----------
    // หน้าร้านสาธารณะอ่านเมนูได้ / แก้ไขเฉพาะ admin หรือ store
    match /menus/{id} {
      allow read: if true;
      allow write: if role() == "admin" || (role() == "store" && isApprovedOrLegacy());
    }
    match /options/{id} {
      allow read: if true;
      allow write: if role() == "admin" || (role() == "store" && isApprovedOrLegacy());
    }

    // ---------- orders ----------
    match /orders/{orderId} {
      // ลูกค้าสั่งจากหน้าร้านสาธารณะ -> สร้างออเดอร์ได้
      allow create: if true;

      // สถานะที่ถือว่า "พร้อมส่ง / รอไรเดอร์รับ" (รองรับทั้งระบบเก่า/ใหม่)
      // หมายเหตุ: "delivering"/"picked_up" ไม่อยู่ในกลุ่มนี้ เพราะหมายถึงงานที่มีไรเดอร์รับแล้ว
      // (เข้าถึงได้เฉพาะผ่าน riderId == uid เท่านั้น ไม่เปิดให้ไรเดอร์คนอื่นแย่งงาน)
      function isReadyForDelivery() {
        return resource.data.status == "กำลังจัดส่ง" ||
               resource.data.status == "ส่งให้ไรเดอร์" ||
               resource.data.status == "ready_for_delivery";
      }

      // อ่าน (store/rider ต้อง approved แล้วเท่านั้น - ร้าน/ไรเดอร์ที่ pending เข้าไม่ได้)
      allow read: if
        role() == "admin" ||
        (role() == "store" && isApprovedOrLegacy()) ||
        (role() == "customer" && resource.data.phone == myPhone()) ||
        (role() == "rider" && isApprovedOrLegacy() &&
          (resource.data.riderId == request.auth.uid || isReadyForDelivery()));

      // ลูกค้าเจ้าของออเดอร์อัปโหลด/ส่งสลิปชำระเงินได้ (PromptPay / โอน) — จำกัดเฉพาะ
      // ฟิลด์ที่ submitSlip แตะจริง (payment / timeline / audit) เท่านั้น ห้ามแก้ราคา
      // รายการ เบอร์ ฯลฯ ; บังคับให้ payment.method คงเดิม (กันแก้วิธีชำระ) และ
      // payment.status ได้แค่ "pending_verification" (ส่งสลิปให้ร้านตรวจ ไม่ใช่ตั้ง
      // approved เอง). เดิมไม่มี rule นี้เลย -> การเขียน URL สลิปลง Firestore ถูกปฏิเสธ
      // ทำให้อัปโหลดสลิปไม่สำเร็จและร้านไม่ได้รับสลิป
      function isCustomerSlipUpdate() {
        return role() == "customer" &&
          resource.data.phone == myPhone() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["payment", "timeline", "audit"]) &&
          request.resource.data.payment.method == resource.data.payment.method &&
          request.resource.data.payment.status == "pending_verification";
      }

      // แก้ไข / เปลี่ยนสถานะ / ยกเลิก
      // admin/store(approved) = เต็มสิทธิ์ ; rider(approved) = เฉพาะงานที่รับ (หรือพร้อมส่งเพื่อรับงาน)
      // customer = เฉพาะการส่งสลิปของออเดอร์ตัวเอง (isCustomerSlipUpdate)
      allow update: if
        role() == "admin" ||
        (role() == "store" && isApprovedOrLegacy()) ||
        (role() == "rider" && isApprovedOrLegacy() &&
          (resource.data.riderId == request.auth.uid || isReadyForDelivery())) ||
        isCustomerSlipUpdate();

      // ลบ = admin หรือ store
      allow delete: if role() == "admin" || role() == "store";
    }

    // ---------- chats (ลูกค้า <-> ไรเดอร์) ----------
    // เดิม: ใครก็ได้ที่ล็อกอิน (role ไหนก็ได้) อ่านแชท "ทุกออเดอร์" ได้ทั้งหมด และ create ได้
    // โดยไม่ตรวจว่า sender ตรงกับ role จริงไหม -> ลูกค้าคนหนึ่งอ่านบทสนทนาของลูกค้าคนอื่นได้
    // และไรเดอร์ปลอมเป็น sender:"customer" ได้ (ดู CLAUDE.md §8)
    // ตอนนี้ผูกสิทธิ์กับ "ออเดอร์ของข้อความนั้น" โดยใช้เกณฑ์เดียวกับ /orders ด้านบน
    match /chats/{chatId} {
      // อ่านออเดอร์ที่ข้อความอ้างถึง (get() ผลลัพธ์ถูก cache ต่อ request และ query แชท
      // กรองด้วย orderId ค่าเดียวเสมอ จึงเป็น path เดียวกันทุก doc)
      function chatOrder(orderId) {
        return get(/databases/$(database)/documents/orders/$(orderId)).data;
      }
      // คู่สนทนาของออเดอร์นี้เท่านั้น (+ ร้าน/แอดมินไว้ดูแลเคสมีปัญหา)
      function isChatParty(o) {
        return role() == "admin" ||
               (role() == "store" && isApprovedOrLegacy()) ||
               (role() == "customer" && o.phone == myPhone()) ||
               (role() == "rider" && isApprovedOrLegacy() && o.riderId == request.auth.uid);
      }
      allow read: if isSignedIn() && isChatParty(chatOrder(resource.data.orderId));

      // ส่งข้อความได้เฉพาะลูกค้าเจ้าของออเดอร์ กับไรเดอร์ที่ถืองานนั้นอยู่จริง
      // และ sender ต้องตรงกับ role จริงของผู้ส่ง (กันปลอมเป็นอีกฝั่ง)
      allow create: if isSignedIn() &&
        (role() == "customer" || role() == "rider") &&
        request.resource.data.sender == role() &&
        isChatParty(chatOrder(request.resource.data.orderId));

      allow update, delete: if false;
    }

    // ---------- stores (เปิด/ปิดร้าน) ----------
    // ลูกค้าหน้าร้านสาธารณะอ่านสถานะร้านได้ ; แก้ไขเฉพาะ store/admin
    match /stores/{id} {
      allow read: if true;
      allow write: if role() == "admin" || (role() == "store" && isApprovedOrLegacy());
    }

    // ---------- reviews ----------
    // ลูกค้าเขียนรีวิวได้ ; ทุก role ที่เกี่ยวข้องอ่านได้
    match /reviews/{id} {
      allow read: if role() == "admin" || role() == "store" ||
                     role() == "rider" || role() == "customer";
      allow create: if role() == "customer";
      allow update, delete: if false;
    }

    // ---------- blockedCustomers ----------
    // หน้าร้านสาธารณะต้องตรวจสอบได้ว่าเบอร์ถูกบล็อกไหม ; แก้ไขเฉพาะ admin
    match /blockedCustomers/{phone} {
      allow read: if true;
      allow write: if role() == "admin";
    }

    // ---------- counters (เลขออเดอร์รันต่อวัน) ----------
    // หน้าร้านสาธารณะต้องเพิ่มเลขรันได้ตอนสร้างออเดอร์
    match /counters/{id} {
      allow read, write: if true;
    }

    // ---------- notifications (Notification Center — Phase 3.7G) ----------
    // recipient key (userId): customer=phone, rider=uid, store/admin="" (role-broadcast).
    // อ่าน/แก้/ลบ ได้เฉพาะเจ้าของ (role ตรง + userId ตรง uid/phone หรือ broadcast) ;
    // สร้างได้ทุกผู้ใช้ที่ล็อกอิน (actor แจ้งเตือนถึง role อื่น — เหมือน orders ที่ create เปิดกว้าง)
    match /notifications/{id} {
      function isMine() {
        return isSignedIn() &&
          resource.data.role == role() &&
          (resource.data.userId == "" ||
           resource.data.userId == request.auth.uid ||
           resource.data.userId == myPhone());
      }
      allow read: if isMine();
      allow create: if isSignedIn();
      allow update, delete: if isMine();
    }

    // ---------- deny all others ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
