rules_version = '2';

// ============================================================================
// LK Fried Chicken — Firestore Security Rules (production)
//
// Collections in this app: users (+users/addresses), orders, chats, chatMeta,
// stores, menus, options, reviews, blockedCustomers, counters, notifications.
//
// NOTE — the Admin UI shows "payments", "riders", "settings", "reports" tabs,
// but those are NOT Firestore collections: riders are users with role=="rider",
// payment lives on order.payment, store settings live on the stores doc, and
// reports are derived from orders. There is therefore no top-level rule for them;
// the deny-all catch-all at the bottom blocks any such path.
//
// Trust model: role/status/approval live on users/{uid} and are set at
// registration (create) or by an admin; end users can never elevate themselves.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers (identity / role / approval) ----------
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function role()    { return isSignedIn() ? userDoc().role : ""; }
    function myPhone() { return isSignedIn() ? userDoc().phone : ""; }

    // ไม่มีฟิลด์ status = บัญชีเก่าก่อนมีระบบอนุมัติ ถือว่าอนุมัติแล้ว (ไม่ล็อกผู้ใช้เดิม)
    function myStatus()          { return isSignedIn() ? userDoc().status : null; }
    function isApprovedOrLegacy(){ return myStatus() == null || myStatus() == "approved" || myStatus() == "active"; }

    function isAdmin() { return role() == "admin"; }
    function isApprovedStore() { return role() == "store" && isApprovedOrLegacy(); }

    // The one order-party predicate, shared by /chats and /chatMeta (was duplicated).
    // Only the two parties of THIS order (its customer + assigned rider) — plus store/admin
    // for support — may touch its conversation / meta.
    function orderParty(o) {
      return isAdmin() ||
             isApprovedStore() ||
             (role() == "customer" && o.phone == myPhone()) ||
             (role() == "rider" && isApprovedOrLegacy() && o.riderId == request.auth.uid);
    }
    function orderById(id) { return get(/databases/$(database)/documents/orders/$(id)).data; }

    // ---------- users (also the "riders" store: role=="rider") ----------
    // read: only the owner or an admin.
    // create: signup only — may self-assign status "active" (customer) or "pending"
    //   (store/rider); can never self-create as "approved".
    // update: the owner may edit their production profile fields, but NOT these backend-only
    //   / identity fields — this blocks privilege escalation (role→admin), status self-
    //   approval, email/uid/createdAt tampering, and rider verification/wallet/income/rating/
    //   riderCode edits. Admin may edit everything (approvals included).
    match /users/{uid} {
      function locksProtectedFields() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(["uid", "role", "status", "email", "createdAt",
                   "riderCode", "verification", "wallet", "income", "rating"]);
      }

      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid) &&
        (request.resource.data.status == "active" || request.resource.data.status == "pending");

      allow update: if isAdmin() || (isOwner(uid) && !locksProtectedFields());

      allow delete: if isAdmin();

      // ---------- users/{uid}/addresses (customer delivery address book) ----------
      // Owner has full read/write on their own addresses ; admin may read (customer support).
      match /addresses/{addressId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid);
      }
    }

    // ---------- menus / options (public storefront reads; store/admin writes) ----------
    match /menus/{id} {
      allow read: if true;
      allow write: if isAdmin() || isApprovedStore();
    }
    match /options/{id} {
      allow read: if true;
      allow write: if isAdmin() || isApprovedStore();
    }

    // ---------- orders ----------
    match /orders/{orderId} {
      // "พร้อมส่ง / รอไรเดอร์รับ" (รองรับทั้งค่าใหม่/เก่า). picked_up/delivering ไม่อยู่ในกลุ่มนี้
      // (เข้าถึงได้เฉพาะไรเดอร์เจ้าของงาน riderId == uid) เพื่อไม่ให้ไรเดอร์อื่นแย่งงาน
      function isReadyForDelivery() {
        return resource.data.status == "กำลังจัดส่ง" ||
               resource.data.status == "ส่งให้ไรเดอร์" ||
               resource.data.status == "ready_for_delivery";
      }
      function isTerminal() {
        return resource.data.status == "completed" || resource.data.status == "cancelled";
      }
      function statusUnchanged() { return request.resource.data.status == resource.data.status; }

      // The only forward transitions a RIDER may drive (mirrors orderStateMachine): claim a
      // ready order → picked_up → delivering → completed. Anything else (backward jumps,
      // cancelling, arbitrary status) is rejected here regardless of what the client sends.
      function validRiderTransition() {
        return (isReadyForDelivery() && request.resource.data.status == "picked_up") ||
               (resource.data.status == "picked_up" && request.resource.data.status == "delivering") ||
               (resource.data.status == "delivering" && request.resource.data.status == "completed");
      }

      // create: the storefront is public (customers can order WITHOUT an account), so create
      // is intentionally open — App Check is the right next layer to curb anonymous abuse.
      allow create: if true;

      // read: admin & approved store see all ; customer sees their own (by phone) ; rider sees
      // orders they hold, or any ready order (to pick one up).
      allow read: if
        isAdmin() ||
        isApprovedStore() ||
        (role() == "customer" && resource.data.phone == myPhone()) ||
        (role() == "rider" && isApprovedOrLegacy() &&
          (resource.data.riderId == request.auth.uid || isReadyForDelivery()));

      // Customer may only attach a payment slip to THEIR OWN, non-terminal order — limited to
      // payment/timeline/audit, keeping payment.method and forcing payment.status to
      // "pending_verification" (they can't self-approve). Cannot touch a completed/cancelled order.
      function isCustomerSlipUpdate() {
        return role() == "customer" &&
          resource.data.phone == myPhone() &&
          !isTerminal() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["payment", "timeline", "audit"]) &&
          request.resource.data.payment.method == resource.data.payment.method &&
          request.resource.data.payment.status == "pending_verification";
      }

      // update:
      //   admin / approved store = full control (the store owns every order in this single-
      //     store app; state-machine validation is enforced server-side in orderEngine).
      //   rider (approved) = only orders they hold or a ready one, AND only a valid forward
      //     transition or a same-status field update (riderStage / arrival timestamps / nearPressed).
      //   customer = slip submission only (isCustomerSlipUpdate).
      allow update: if
        isAdmin() ||
        isApprovedStore() ||
        (role() == "rider" && isApprovedOrLegacy() &&
          (resource.data.riderId == request.auth.uid || isReadyForDelivery()) &&
          (statusUnchanged() || validRiderTransition())) ||
        isCustomerSlipUpdate();

      // delete: admin or store only.
      allow delete: if isAdmin() || role() == "store";
    }

    // ---------- chats (customer <-> rider messages) ----------
    // Bound to the message's order: only that order's parties (+ store/admin) may read, and a
    // message may only be created by a real party whose sender matches their true role (no
    // impersonating the other side). Messages are immutable (no edit/delete).
    match /chats/{chatId} {
      allow read: if isSignedIn() && orderParty(orderById(resource.data.orderId));
      allow create: if isSignedIn() &&
        (role() == "customer" || role() == "rider") &&
        request.resource.data.sender == role() &&
        orderParty(orderById(request.resource.data.orderId));
      allow update, delete: if false;
    }

    // ---------- chatMeta (read receipts + typing + unread, one doc per order) ----------
    // chatMeta/{orderId} holds <role>LastRead / <role>Typing / typingAt. Same party gate as
    // /chats. Powers the typing indicator, read receipts and unread counts in realtime chat.
    match /chatMeta/{orderId} {
      allow read, write: if isSignedIn() && orderParty(orderById(orderId));
    }

    // ---------- stores (open/close + store settings live here) ----------
    // Public storefront reads store status ; only store/admin write.
    match /stores/{id} {
      allow read: if true;
      allow write: if isAdmin() || isApprovedStore();
    }

    // ---------- reviews ----------
    // Any involved role may read ; customers create ; immutable afterwards.
    match /reviews/{id} {
      allow read: if role() == "admin" || role() == "store" ||
                     role() == "rider" || role() == "customer";
      allow create: if role() == "customer";
      allow update, delete: if false;
    }

    // ---------- blockedCustomers ----------
    // Public storefront must be able to check if a phone is blocked ; only admin writes.
    match /blockedCustomers/{phone} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- counters (daily running order number) ----------
    // The public storefront increments this while creating an anonymous order, so it stays
    // open like order-create. App Check is the recommended layer to limit anonymous abuse.
    match /counters/{id} {
      allow read, write: if true;
    }

    // ---------- notifications (Notification Center) ----------
    // recipient key (userId): customer=phone, rider=uid, store/admin="" (role-broadcast).
    // Owner (matching role + uid/phone, or a role broadcast) may read/modify/delete ; any
    // signed-in actor may create (to notify another role, like the open order-create).
    match /notifications/{id} {
      function isMine() {
        return isSignedIn() &&
          resource.data.role == role() &&
          (resource.data.userId == "" ||
           resource.data.userId == request.auth.uid ||
           resource.data.userId == myPhone());
      }
      allow read: if isMine();
      allow create: if isSignedIn();
      allow update, delete: if isMine();
    }

    // ---------- deny everything else (incl. any future/unknown collection) ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
